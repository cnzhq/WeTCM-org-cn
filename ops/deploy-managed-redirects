#!/usr/bin/env bash
set -Eeuo pipefail

if [[ $EUID -ne 0 ]]; then
  echo "This deployer must run as root." >&2
  exit 1
fi

deploy_dir=/tmp/managed-redirects
site_available=/etc/nginx/sites-available/managed-redirects.conf
site_enabled=/etc/nginx/sites-enabled/managed-redirects.conf
legacy_available=/etc/nginx/sites-available/zhq.info
legacy_enabled=/etc/nginx/sites-enabled/zhq.info
had_config=0
disabled_legacy=0

for required_file in bootstrap.conf final.conf certificates.tsv; do
  if [[ ! -f "$deploy_dir/$required_file" || -L "$deploy_dir/$required_file" ]]; then
    echo "Missing or unsafe deployment file: $deploy_dir/$required_file" >&2
    exit 1
  fi
done

backup_file=$(mktemp)
verification_headers=$(mktemp)
verification_error=$(mktemp)

if [[ -f "$site_available" ]]; then
  cp "$site_available" "$backup_file"
  had_config=1
fi

rollback() {
  echo "Deployment failed; restoring the previous Nginx state." >&2
  if [[ $had_config -eq 1 ]]; then
    cp "$backup_file" "$site_available"
    ln -sfn "$site_available" "$site_enabled"
  else
    rm -f "$site_available" "$site_enabled"
  fi
  if [[ $disabled_legacy -eq 1 ]]; then
    ln -sfn "$legacy_available" "$legacy_enabled"
  fi
  nginx -t && systemctl reload nginx || true
  rm -f "$backup_file" "$verification_headers" "$verification_error"
}
trap rollback ERR

# Migrate the one-domain configuration created by the older workflow.
if [[ -L "$legacy_enabled" ]] && \
   grep -Fq 'return 302 https://wetcm.org.cn$request_uri;' "$legacy_available"; then
  rm -f "$legacy_enabled"
  disabled_legacy=1
fi

mkdir -p /var/www/certbot
install -m 0644 "$deploy_dir/bootstrap.conf" "$site_available"
ln -sfn "$site_available" "$site_enabled"
nginx -t
systemctl reload nginx

command -v certbot >/dev/null 2>&1
while IFS=$'\t' read -r certificate_name domain_list; do
  certbot_domains=()
  issue_certificate=0
  expand_certificate=()
  for domain in $domain_list; do
    certbot_domains+=( -d "$domain" )
  done

  certificate_path="/etc/letsencrypt/live/$certificate_name/fullchain.pem"
  if [[ ! -s "$certificate_path" ]]; then
    issue_certificate=1
  else
    current_names=$(openssl x509 -in "$certificate_path" -noout -ext subjectAltName | \
      tr ',' '\n' | sed -n 's/^ *DNS://p')
    for domain in $domain_list; do
      if ! grep -Fxq "$domain" <<<"$current_names"; then
        issue_certificate=1
        expand_certificate=( --expand )
      fi
    done
  fi

  if [[ $issue_certificate -eq 1 ]]; then
    certbot certonly \
      --webroot \
      --webroot-path /var/www/certbot \
      --non-interactive \
      --agree-tos \
      --cert-name "$certificate_name" \
      "${expand_certificate[@]}" \
      "${certbot_domains[@]}"
  fi
done < "$deploy_dir/certificates.tsv"

install -m 0644 "$deploy_dir/final.conf" "$site_available"
nginx -t
systemctl reload nginx

while IFS=$'\t' read -r certificate_name domain_list; do
  verified=0
  for attempt in {1..15}; do
    : > "$verification_headers"
    : > "$verification_error"
    echo "Verifying https://$certificate_name/ against local Nginx (attempt $attempt/15)..."
    if curl \
      --noproxy '*' \
      --fail \
      --silent \
      --show-error \
      --head \
      --connect-timeout 2 \
      --max-time 4 \
      --dump-header "$verification_headers" \
      --output /dev/null \
      --resolve "$certificate_name:443:127.0.0.1" \
      "https://$certificate_name/" \
      2>"$verification_error"; then
      verified=1
      echo "Local HTTPS verification succeeded for $certificate_name:"
      cat "$verification_headers"
      break
    fi

    echo "Verification attempt $attempt failed for $certificate_name:" >&2
    cat "$verification_error" >&2
    if [[ $attempt -lt 15 ]]; then
      sleep 1
    fi
  done

  if [[ $verified -ne 1 ]]; then
    echo "Local HTTPS verification failed for $certificate_name after 15 attempts." >&2
    false
  fi
done < "$deploy_dir/certificates.tsv"

trap - ERR
rm -f "$backup_file" "$verification_headers" "$verification_error"
rm -rf "$deploy_dir"
